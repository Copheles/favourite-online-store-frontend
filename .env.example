# ---------------------------------------------------------------------------
# Local development (Vite -> backend on localhost:3000)
# ---------------------------------------------------------------------------
# VITE_API_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Cloudflare Workers Builds deploy (GitHub connect)
# ---------------------------------------------------------------------------
# Production defaults to the real API domain:
# https://api.copheles.online
#
# Set this as a build-time env var in the Cloudflare Workers dashboard:
# VITE_API_URL=https://api.copheles.online
#
# Dashboard build settings:
# Root directory: frontend
# Build command: npm run build
# SPA routing: public/_redirects (/* /index.html 200)

# ---------------------------------------------------------------------------
# Direct cross-origin API (not recommended with ngrok free tier)
# ---------------------------------------------------------------------------
# VITE_API_URL=https://abc123.ngrok-free.app
